# .env.local — このファイルをGitにコミットしないこと（.gitignoreに追加済み）

# ── Anthropic ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Firebase（クライアント側・NEXT_PUBLIC_ プレフィックス必須）─
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# ── Firebase Admin（サーバー側・絶対に公開しないこと）──────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# 改行を \n に変換して1行で入れること
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ── Stripe ─────────────────────────────────────────────
# → https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
# → https://dashboard.stripe.com/products で商品・価格を作成して取得
STRIPE_PRICE_ONE_TIME=price_xxxxxxxxxxxxxxxxxxxxxxxx   # 都度課金 ¥500
STRIPE_PRICE_SUB_LIGHT=price_xxxxxxxxxxxxxxxxxxxxxxxx  # サブスク ¥300/月
STRIPE_PRICE_SUB_STD=price_xxxxxxxxxxxxxxxxxxxxxxxx    # サブスク ¥500/月
# → アプリのベースURL（Stripe リダイレクト先）
NEXT_PUBLIC_BASE_URL=https://settlabs.app/contract_reader

# ── Google AdSense ─────────────────────────────────────
# → https://www.google.com/adsense/ でパブリッシャーIDと広告ユニットIDを取得
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-xxxxxxxxxxxxxxxx
# 広告スロットID（AdSense管理画面で広告ユニットを作成して取得）
NEXT_PUBLIC_ADSENSE_SLOT_TOP=0000000000
NEXT_PUBLIC_ADSENSE_SLOT_ANALYZING=0000000000
NEXT_PUBLIC_ADSENSE_SLOT_RESULT=0000000000
